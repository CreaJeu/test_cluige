<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="test_cluige" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/test_cluige" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-fPIC" />
					<Add option="-g" />
					<Add option="-DCLUIGE_DEBUG" />
				</Compiler>
				<Linker>
					<Add library="/usr/lib/x86_64-linux-gnu/libcurses.so" />
					<Add library="../cluige/bin/Debug/libcluige.so" />
					<Add directory="../cluige/bin/Debug" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/test_cluige" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add library="../cluige/bin/Release/libcluige.dll" />
					<Add directory="../cluige/bin/Release" />
				</Linker>
			</Target>
			<Target title="DebugLinux">
				<Option output="bin/Debug/test_cluige" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option additional_output="../cluige_microCommits/bin/Debug/libcluige.so;" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-fPIC" />
					<Add option="-O0" />
					<Add option="-ggdb3" />
					<Add option="-DCLUIGE_DEBUG" />
				</Compiler>
				<Linker>
					<Add option="-static-libgcc" />
					<Add option="-Wl,-rpath,&apos;\\$$$$ORIGIN&apos;" />
					<Add library="XCurses" />
					<Add library="cluige" />
					<Add directory="../PDCurses/x11" />
					<Add directory="../cluige/bin/Debug" />
					<Add directory="." />
				</Linker>
			</Target>
			<Target title="ReleaseLinux">
				<Option output="bin/Release/test_cluige" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option additional_output="../cluige_microCommits/bin/Release/libcluige.so;" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-fPIC" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add option="-static-libgcc" />
					<Add option="-Wl,-rpath,&apos;\\$$$$ORIGIN&apos;" />
					<Add library="XCurses" />
					<Add library="cluige" />
					<Add directory="../PDCurses/x11" />
					<Add directory="../cluige/bin/Release" />
					<Add directory="." />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-std=c11" />
			<Add directory="../cluige" />
		</Compiler>
		<Linker>
			<Add option="-static-libgcc" />
